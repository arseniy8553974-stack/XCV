        if Settings.AntiDisaster and LocalPlayer.Character then
            for _, obj in ipairs(Workspace:GetDescendants()) do
                if obj:IsA("BasePart") and (obj.Name:lower():find("tornado") or obj.Name:lower():find("meteor") or obj.Name:lower():find("lava")) then
