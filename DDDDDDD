-- ПОЛЁТ
local flying = false
local flySpeed = 60
local bg, bv

local function startFly()
    local char = LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    local hum = char and char:FindFirstChild("Humanoid")
    if not root or not hum then return end
    flying = true
    bg = Instance.new("BodyGyro")
    bg.P = 9e4
    bg.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
    bg.CFrame = root.CFrame
    bg.Parent = root
    bv = Instance.new("BodyVelocity")
    bv.MaxForce = Vector3.new(9e9, 9e9, 9e9)
    bv.Velocity = Vector3.zero
    bv.Parent = root
    hum.PlatformStand = true
end

local function stopFly()
    flying = false
    if bg then bg:Destroy() end
    if bv then bv:Destroy() end
    local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid")
    if hum then hum.PlatformStand = false end
end

UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if input.KeyCode == Enum.KeyCode.F and Settings.Fly then
        if flying then stopFly() else startFly() end
    end
end)

RunService.RenderStepped:Connect(function()
    if flying and Settings.Fly then
        local root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if root then
            local cam = workspace.CurrentCamera
            local move = Vector3.zero
            if UserInputService:IsKeyDown(Enum.KeyCode.W) then move += cam.CFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then move -= cam.CFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then move -= cam.CFrame.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then move += cam.CFrame.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.Space) then move += Vector3.new(0, 1, 0) end
            if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then move -= Vector3.new(0, 1, 0) end
            if bv then bv.Velocity = move * flySpeed end
            if bg then bg.CFrame = cam.CFrame end
        end
    end
end)

-- МАГНИТ ДЛЯ БЛОКОВ
local orbitingBlocks = {}

spawn(function()
    while true do
        wait(0.1)
        if Settings.BlockMagnet and LocalPlayer.Character then
            local root = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            if root then
                for _, obj in ipairs(Workspace:GetDescendants()) do
                    if obj:IsA("BasePart") and (obj.Name:lower():find("brick") or obj.Name:lower():find("block")) then
                        local block = Instance.new("Part")
                        block.Size = obj.Size
                        block.Shape = obj.Shape
                        block.Color = obj.Color
                        block.Material = obj.Material
                        block.Transparency = 0.3
                        block.Anchored = true
                        block.CanCollide = false
                        block.Parent = workspace
                        table.insert(orbitingBlocks, block)
                        obj:Destroy()
                    end
                end
            end
        end
    end
end)

spawn(function()
    local angle = 0
    while true do
        RunService.RenderStepped:Wait()
        if Settings.BlockMagnet and LocalPlayer.Character then
            local root = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            if root then
                angle = angle + 0.1
                for i, block in ipairs(orbitingBlocks) do
                    if block and block.Parent then
                        local offset = Vector3.new(math.cos(angle + i) * 5, math.sin(angle * 0.5 + i) * 3, math.sin(angle + i) * 5)
                        block.Position = root.Position + offset
                        block.Orientation = Vector3.new(angle * 50, angle * 30, angle * 70)
                    end
                end
            end
        end
    end
end)

-- УБИЙСТВЕННАЯ АУРА
spawn(function()
    while true do
        wait(0.5)
        if Settings.KillAura and LocalPlayer.Character then
            local root = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            if root then
                for _, player in ipairs(Players:GetPlayers()) do
                    if player ~= LocalPlayer and player.Character then
                        local hum = player.Character:FindFirstChild("Humanoid")
                        local hrp = player.Character:FindFirstChild("HumanoidRootPart")
                        if hum and hrp and (hrp.Position - root.Position).Magnitude < 20 then
                            hum.Health = 0
                        end
                    end
                end
            end
        end
    end
end)

-- АВТО-ФЕРМА
spawn(function()
    while true do
        wait(1)
        if Settings.AutoFarm and LocalPlayer.Character then
            local char = LocalPlayer.Character
            local root = char:FindFirstChild("HumanoidRootPart")
            if root then
                -- Телепорт в безопасную зону и сбор наград
                for _, obj in ipairs(Workspace:GetDescendants()) do
                    if obj:IsA("BasePart") and obj.Name == "SafeZone" then
                        root.CFrame = obj.CFrame + Vector3.new(0, 5, 0)
                    end
                end
            end
        end
    end
end)

-- АНТИ-СТИХИЯ (защита от торнадо, метеоров и т.д.)
spawn(function()
